# ──────────────────────────────────────────────────
# {{ project_name }} — Environment Variables Example
# Generated by MCPer on {{ generated_at }}
#
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────
{% for api in apis %}
# ── {{ api.title }} ──
# Base URL for {{ api.title }} requests
{{ api.prefix | upper }}_BASE_URL={{ api.base_url }}
{% if api.auth_type == "bearer" %}
# Bearer token / personal access token for {{ api.title }}
{{ api.env_var_name }}=your-api-token-here
{% elif api.auth_type == "apiKey" %}
# API key for {{ api.title }} — sent as the '{{ api.api_key_header }}' header
{{ api.env_var_name }}=your-api-key-here
{% elif api.auth_type == "basic" %}
# Basic auth for {{ api.title }}
{{ api.env_var_name }}_USERNAME=your-username
{{ api.env_var_name }}_PASSWORD=your-password
{% else %}
# No auth scheme auto-detected for {{ api.title }}.
# If this API requires a token, uncomment and fill in the line below:
# {{ api.prefix | upper }}_API_KEY=your-api-key-here
{% endif %}
{% endfor %}

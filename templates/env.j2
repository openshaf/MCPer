# ──────────────────────────────────────────────────
# {{ project_name }} — Environment Variables
# Generated by MCPer on {{ generated_at }}
#
# Fill in your API keys below, then run the server.
# This file is for LOCAL use only — add it to .gitignore.
# ──────────────────────────────────────────────────
{% for api in apis %}
# ── {{ api.title }} ──
{{ api.prefix | upper }}_BASE_URL={{ api.base_url }}
{% if api.auth_type == "bearer" %}
# Bearer token / personal access token for {{ api.title }}
{{ api.env_var_name }}=
{% elif api.auth_type == "apiKey" %}
# API key for {{ api.title }} (sent as header: {{ api.api_key_header }})
{{ api.env_var_name }}=
{% elif api.auth_type == "basic" %}
# Basic auth credentials for {{ api.title }}
{{ api.env_var_name }}_USERNAME=
{{ api.env_var_name }}_PASSWORD=
{% else %}
# No auth scheme detected for {{ api.title }}.
# If this API requires a token, uncomment and fill in the line below:
# {{ api.prefix | upper }}_API_KEY=
{% endif %}
{% endfor %}

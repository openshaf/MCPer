if __name__ == "__main__":
    import argparse
    parser = argparse.ArgumentParser(description=f"Run the {{ project_name }} MCP server")
    parser.add_argument("--sse", action="store_true", help="Run as an HTTP Server-Sent Events (SSE) endpoint")
    parser.add_argument("--host", type=str, default="0.0.0.0", help="Host to bind the SSE server to")
    parser.add_argument("--port", type=int, default=8000, help="Port to bind the SSE server to")
    args = parser.parse_args()

    if args.sse:
        print(f"🚀 Starting {{ project_name }} MCP Server as an HTTP endpoint...")
        print(f"Listening on http://{args.host}:{args.port}/sse")
        mcp.run(transport="sse", host=args.host, port=args.port)
    else:
        mcp.run(transport="stdio")

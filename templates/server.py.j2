from __future__ import annotations

import json
import os

from dotenv import load_dotenv
import httpx
from fastmcp import FastMCP

# Load environment variables from .env (API keys, base URLs)
load_dotenv()

mcp = FastMCP("{{ project_name }}")

# ---------------------------------------------------------------------------
# API Configurations
# ---------------------------------------------------------------------------
{% for api in apis %}
# --- {{ api.title }} ---
{{ api.prefix | upper }}_BASE_URL = os.environ.get("{{ api.prefix | upper }}_BASE_URL", "{{ api.base_url }}").rstrip("/")

{% if api.auth_type == "bearer" %}
_{{ api.prefix | upper }}_API_KEY = os.environ.get("{{ api.env_var_name }}", "")


def _{{ api.prefix | lower }}_headers() -> dict:
    return {"Authorization": f"Bearer {_{{ api.prefix | upper }}_API_KEY}"} if _{{ api.prefix | upper }}_API_KEY else {}
{% elif api.auth_type == "apiKey" %}
_{{ api.prefix | upper }}_API_KEY = os.environ.get("{{ api.env_var_name }}", "")


def _{{ api.prefix | lower }}_headers() -> dict:
    return {"{{ api.api_key_header }}": _{{ api.prefix | upper }}_API_KEY} if _{{ api.prefix | upper }}_API_KEY else {}
{% elif api.auth_type == "basic" %}
import base64 as _b64

_{{ api.prefix | upper }}_USER = os.environ.get("{{ api.env_var_name }}_USERNAME", "")
_{{ api.prefix | upper }}_PASS = os.environ.get("{{ api.env_var_name }}_PASSWORD", "")


def _{{ api.prefix | lower }}_headers() -> dict:
    if _{{ api.prefix | upper }}_USER and _{{ api.prefix | upper }}_PASS:
        creds = _b64.b64encode(f"{_{{ api.prefix | upper }}_USER}:{_{{ api.prefix | upper }}_PASS}".encode()).decode()
        return {"Authorization": f"Basic {creds}"}
    return {}
{% else %}
# No auth scheme auto-detected — reads optional {{ api.prefix | upper }}_API_KEY from .env
_{{ api.prefix | upper }}_API_KEY = os.environ.get("{{ api.prefix | upper }}_API_KEY", "")


def _{{ api.prefix | lower }}_headers() -> dict:
    return {"Authorization": f"Bearer {_{{ api.prefix | upper }}_API_KEY}"} if _{{ api.prefix | upper }}_API_KEY else {}
{% endif %}

{% endfor %}
